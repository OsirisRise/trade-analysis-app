# Copy to .env and adjust. Never commit real keys.
DATABASE_URL=postgresql://localhost:5432/trade_analysis

# Metals.Dev (https://metals.dev) — free tier, 100 req/month, no card.
METALS_DEV_API_KEY=your_metals_dev_key_here

# EIA (https://www.eia.gov/opendata/register.php) — free registered key.
# DEMO_KEY works for light testing but has strict shared rate limits.
EIA_API_KEY=your_eia_key_here
